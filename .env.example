# ───────────────────────────────────────────────────────────────────────────
# OpsHub API — environment configuration
# Copy to .env and fill in. Process refuses to start if required vars are missing.
# ───────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL 18) ─────────────────────────────────────────────────
# Port 5433 matches docker-compose.dev.yml — avoids conflict with other local
# Postgres instances (e.g. rally-api on the default 5432).
DATABASE_URL=postgres://opshub:opshub@localhost:5433/opshub
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Auth ─────────────────────────────────────────────────────────────────────
# Scaffold uses HS256 with a shared secret + a dev-login endpoint.
# Production target: Microsoft Entra ID OIDC SSO (see platform docs).
# JWT — ES256 asymmetric keypair (PEM or base64-encoded PEM)
# Generate:  openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt -out private.pem
#            openssl ec -in private.pem -pubout -out public.pem
# Base64 for CI/secrets:  base64 -w0 < private.pem
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
COOKIE_SECRET=change-me-in-prod-min-32-chars-cookie
JWT_ACCESS_EXPIRY=15m
JWT_ISSUER=opshub-api
JWT_AUDIENCE=opshub-web

# ── Microsoft Entra ID SSO (production login) ────────────────────────────────
# Required in production; optional in dev (dev-login is used when these are unset).
# App Role *values* in Azure MUST equal OpsHub role keys (admin, it-admin, security,
# hr, manager, helpdesk, auditor). Full setup: docs/sso-entra-app-roles.md
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Only needed for Microsoft Graph API calls (security posture, profile photos).
ENTRA_CLIENT_SECRET=
GRAPH_CLIENT_SECRET=

# ── Cache (Valkey / Redis — optional in dev) ─────────────────────────────────
# Port 6380 matches docker-compose.dev.yml — avoids conflict with other local
# Redis/Valkey instances (e.g. rally-api on the default 6379).
# Leave empty to disable caching in local development.
REDIS_URL=redis://localhost:6380
REDIS_KEY_PREFIX=opshub:

# ── AWS (optional in dev) ────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
SQS_OUTBOX_URL=

# ── Observability ────────────────────────────────────────────────────────────
SERVICE_VERSION=dev
LOG_LEVEL=info
LOG_PRETTY=true
LOG_SQL=false
# Set OTEL_ENABLED=true to send traces/metrics to an OTLP collector.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=opshub-api
OTEL_WORKER_SERVICE_NAME=opshub-worker
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Email ────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER=dev       → logs emails to console (default, no setup required)
# EMAIL_PROVIDER=resend    → sends via Resend (set RESEND_API_KEY)
EMAIL_PROVIDER=dev
MAIL_FROM_NAME=OpsHub
MAIL_FROM_EMAIL=no-reply@opshub.app
MAIL_REPLY_TO=
RESEND_API_KEY=

# ── App URL (used in email links) ────────────────────────────────────────────
APP_URL=http://localhost:5173

# ── File Storage (S3-compatible) ──────────────────────────────────────────────
S3_FILES_BUCKET=opshub-files-dev
CDN_FILES_BASE_URL=
